# ─────────────────────────────────────────────────────────────────────────────
# MVL Operum — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Compose ────────────────────────────────────────────────────────────
# Unique name for this environment — scopes all Docker resources (networks, volumes)
# Use: mvloperum-staging  OR  mvloperum-prod
COMPOSE_PROJECT_NAME=mvloperum-staging

# Tag of the Docker image to deploy (set by CI/CD to the git SHA)
IMAGE_TAG=latest

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=staging

# Public-facing URL (used client-side and for SSR absolute URL construction)
NEXT_PUBLIC_API_URL=https://staging.operum.mavellium.com.br

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_USER=mvluser
DB_PASSWORD=change-me-staging
DB_NAME=mvloperum_staging
DATABASE_URL=postgresql://mvluser:change-me-staging@postgres:5432/mvloperum_staging

# ── Authentication ────────────────────────────────────────────────────────────
# Legacy HS256 secret — kept for backward compatibility during JWT migration.
# After all existing sessions expire (7 days), this can be removed.
SESSION_SECRET=change-me-at-least-32-characters-long

# RS256 key pair — used for all new sessions.
# Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then inline (replace newlines with \n):
#   JWT_PRIVATE_KEY="$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem)"
#   JWT_PUBLIC_KEY="$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' public.pem)"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── MinIO (S3-compatible Storage) ─────────────────────────────────────────────
MINIO_HOST=minio-staging.mvloperum.com
MINIO_ACCESS_KEY=staging-access-key
MINIO_SECRET_KEY=staging-secret-key-change-me
MINIO_BUCKET=mvloperum-staging
# Public URL for direct file access (MinIO domain exposed via Traefik)
MINIO_PUBLIC_URL=https://minio-staging.mvloperum.com

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Required — Redis runs with --requirepass; generate with: openssl rand -hex 32
REDIS_PASSWORD=change-me-redis-password

# ── Microservices ─────────────────────────────────────────────────────────────
# Set to enable the notification microservice (Strangler Fig Phase 1).
# If unset, the monolith handles notifications directly via Prisma.
NOTIFICATION_SERVICE_URL=http://notification-service:4004

# Required — shared secret between app and notification-service
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change-me-internal-api-key

# ── Observability (production only) ───────────────────────────────────────────
BASE_DOMAIN=mvloperum.com
GRAFANA_PASSWORD=change-me-grafana

# ── Vercel Blob (legacy — only needed for the one-time migration script) ───────
# After running scripts/migrate-blobs.ts, this can be removed.
BLOB_READ_WRITE_TOKEN=
