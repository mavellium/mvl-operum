generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── Minimal referenced models ─────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  REMOVED
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  subdomain String       @unique
  status    TenantStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projects     Project[]
  departments  Department[]
  roles        Role[]
  stakeholders Stakeholder[]
}

model User {
  id       String @id @default(cuid())
  tenantId String
  name     String
  email    String
  role     String @default("member")

  projects         UserProject[]
  departments      UserDepartment[]
  userProjectRoles UserProjectRole[]

  @@unique([email, tenantId])
}

// ── Projects ──────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  ARCHIVED
}

model Project {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  name        String
  description String?

  logoUrl   String?
  slogan    String?
  location  String?
  startDate DateTime?
  endDate   DateTime?

  justificativa     String? @db.Text
  objetivos         String? @db.Text
  metodologia       String? @db.Text
  descricaoProduto  String? @db.Text
  premissas         String? @db.Text
  restricoes        String? @db.Text
  limitesAutoridade String? @db.Text

  semestre      String?
  ano           Int?
  departamentos String[]

  status    ProjectStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members      UserProject[]
  usuariosRole UserProjectRole[]
  macroFases   ProjectMacroFase[]
  stakeholders ProjectStakeholder[]

  @@unique([name, tenantId])
}

model ProjectMacroFase {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fase       String
  dataLimite String?
  custo      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Departments ───────────────────────────────────────────

model Department {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  active      Boolean   @default(true)
  hourlyRate  Float?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users        UserDepartment[]
  userProjects UserProject[]

  @@unique([name, tenantId])
}

model UserDepartment {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
}

model UserProject {
  id           String      @id @default(cuid())
  userId       String
  projectId    String
  active       Boolean     @default(true)
  role         String?
  departmentId String?
  hourlyRate   Float?
  startDate    DateTime    @default(now())
  endDate      DateTime?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([userId, projectId])
}

// ── RBAC ──────────────────────────────────────────────────

enum RoleScope {
  TENANT
  PROJETO
}

model Role {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String    @map("nome")
  nameKey     String    @map("nomeKey")
  scope       RoleScope @map("escopo")
  description String?   @map("descricao")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions      RolePermission[]
  userProjectRoles UserProjectRole[]

  @@unique([nameKey, tenantId, scope])
}

model Permission {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  resource    String
  action      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserProjectRole {
  id        String    @id @default(cuid())
  userId    String
  projectId String    @map("projetoId")
  roleId    String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now()) @map("criadoEm")
  updatedAt DateTime  @updatedAt

  @@unique([userId, projectId])
}

// ── Stakeholders ──────────────────────────────────────────

model Stakeholder {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  logoUrl     String?
  company     String?
  competence  String?
  email       String?
  phone       String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects ProjectStakeholder[]
  tenant   Tenant               @relation(fields: [tenantId], references: [id])
}

model ProjectStakeholder {
  id            String   @id @default(cuid())
  projectId     String
  stakeholderId String
  createdAt     DateTime @default(now())

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@unique([projectId, stakeholderId])
}
