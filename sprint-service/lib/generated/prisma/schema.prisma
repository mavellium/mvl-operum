generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── Minimal referenced models ─────────────────────────────

model Tenant {
  id        String    @id @default(cuid())
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  auditLogs AuditLog[]
}

model User {
  id       String @id @default(cuid())
  tenantId String
  name     String
  email    String

  sprints          Sprint[]
  timeEntries      TimeEntry[]
  responsibleCards CardResponsible[]
  comments         Comment[]
  dashboardMetrics DashboardMetric[]
  sprintFeedbacks  SprintFeedback[]

  tags Tag[]

  @@unique([email, tenantId])
}

model Project {
  id       String @id @default(cuid())
  tenantId String
  name     String

  sprints Sprint[]
}

// ── Sprints ───────────────────────────────────────────────

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model Sprint {
  id          String       @id @default(cuid())
  name        String
  description String?
  status      SprintStatus @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  qualidade   Float?
  dificuldade Float?
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  createdBy   String?
  creator     User?        @relation(fields: [createdBy], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  cards            Card[]
  sprintColumns    SprintColumn[]
  dashboardMetrics DashboardMetric[]
  sprintFeedbacks  SprintFeedback[]
}

model SprintColumn {
  id        String    @id @default(cuid())
  title     String
  position  Int
  sprintId  String
  sprint    Sprint    @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  cards     Card[]    @relation("SprintColumnCards")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ── Cards ─────────────────────────────────────────────────

model Card {
  id             String        @id @default(cuid())
  title          String
  description    String        @default("")
  color          String        @default("#6b7280")
  position       Int           @default(0)
  sprintId       String
  sprint         Sprint        @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  sprintColumnId String?
  sprintColumn   SprintColumn? @relation("SprintColumnCards", fields: [sprintColumnId], references: [id], onDelete: SetNull)
  sprintPosition Int?
  priority       String        @default("media")
  tagsImport     String        @default("")
  startDate      DateTime?
  endDate        DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tags         CardTag[]
  attachments  Attachment[]
  timeEntries  TimeEntry[]
  responsibles CardResponsible[]
  comments     Comment[]
}

model Tag {
  id       String    @id @default(cuid())
  tenantId String
  name     String
  color    String    @default("#6b7280")
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards    CardTag[]

  @@unique([name, userId])
}

model CardTag {
  cardId String
  tagId  String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
}

model CardResponsible {
  cardId String
  userId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
}

// ── Comments ──────────────────────────────────────────────

enum CommentType {
  COMMENT
  FEEDBACK
}

model Comment {
  id        String      @id @default(cuid())
  cardId    String
  card      Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  type      CommentType @default(COMMENT)
  reactions Json?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ── Attachment ────────────────────────────────────────────

model Attachment {
  id         String    @id @default(cuid())
  cardId     String
  card       Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  filePath   String
  fileSize   Int
  isCover    Boolean   @default(false)
  deletedAt  DateTime?
  uploadedAt DateTime  @default(now())
}

// ── Time Entries ──────────────────────────────────────────

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  cardId      String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  duration    Int       @default(0)
  description String?
  isRunning   Boolean   @default(false)
  isManual    Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Dashboard ─────────────────────────────────────────────

model DashboardMetric {
  id               String   @id @default(cuid())
  sprintId         String
  sprint           Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  horas            Float    @default(0)
  tarefasPendentes Int      @default(0)
  custoTotal       Float    @default(0)
  rankingPosicao   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sprintId, userId])
}

model SprintFeedback {
  id                String   @id @default(cuid())
  sprintId          String
  sprint            Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tarefasRealizadas String?
  dificuldades      String?
  qualidade         Int
  dificuldade       Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([sprintId, userId])
}

// ── Audit Log ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  timestamp DateTime @default(now())
}
